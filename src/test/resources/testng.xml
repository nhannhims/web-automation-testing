<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Demo Test Suite" verbose="1" parallel="methods" thread-count="3">
    <parameter name="browser" value="chrome" />

    <listeners>
        <listener class-name="com.demo.listeners.TestListener" />
        <listener class-name="com.demo.listeners.AnnotationTransformer" />
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="com.demo.tests.LoginTest"/>
            <class name="com.demo.tests.RegisterUserTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="com.demo.tests.UserAPITest"/>
        </classes>
    </test>

</suite>
